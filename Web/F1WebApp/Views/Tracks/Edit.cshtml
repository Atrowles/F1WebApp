
<h1>Edit Track</h1>
<div id="addEditbinding" class="rcorners" v-cloak>

    <div id="loading" v-if="showLoading">
        <img src="~/img/spinner.gif" />
    </div>
    <div class="row">
        <div class="col-lg-12 marginbottom  text-left">
            <b>Track Id:{{track.id}}</b>
        </div>
    </div>
    </br>
    <div class="row">
        <div  class="col-lg-6 marginbottom  text-left">
            <span v-if="locationError" class="validation-error">! Invalid Location Value</span>
        </div>
        <div  class="col-lg-6 marginbottom  text-left">
            <span v-if="lengthError" class="validation-error">! Invalid Length Value</span>
        </div>
    </div>
    <div class="row">
        <div class="col-lg-3 marginbottom  text-left">
            <span>Location: </span>
        </div>
        <div class="col-lg-3 marginbottom  text-left">
            <input type="text" v-model="track.location" />
        </div>
        <div class="col-lg-3 marginbottom  text-left">
            <span>Length: </span>
        </div>
        <div class="col-lg-3 marginbottom  text-left">
            <input type="number" step="0.01" v-model="track.length"  />
        </div>
    </div>
    </br>
    <div class="row">
        <div  class="col-lg-6 marginbottom  text-left">
            <span v-if="fastestLapError" class="validation-error">! Invalid Fastest Lap Value</span>
        </div>

    </div>
    <div class="row">
        <div class="col-lg-3 marginbottom  text-left">
            <span>Lap Record: </span>
        </div>
        <div class="col-lg-3 marginbottom  text-left">
            <input type="number" step="0.01" v-model="track.fastestLap"  />
        </div>
    </div>
    </br>
    <div class="row">
        <div class="col-lg-12 marginbottom  text-left"><button v-on:click="validateTrack" class="btn-primary" id="btn_update">Update</button></div>
    </div>
</div>

@section scripts
{
    <script>

        var trackId = @ViewData["Id"];

        require.config({
           baseUrl: "/js"
        });

        require(["VueScripts/tracks/AddEditTrack"],
                        function (v) {

                        }
       );
    </script>
}
