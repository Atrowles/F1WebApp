
@{
    ViewData["Title"] = "Update Page";
}
<h1>Update Race Result</h1>
<div class="text-center">

    <div id="updateDriverResults" v-cloak>
        <!--use v cloak to hide things until its bound properly-->
        <div id="loading" v-if="showLoading">
            <img src="~/img/spinner.gif" />
        </div>

        <div class="row">
            <div class="col-lg-6 marginbottom  text-left">
                <label class="details-label">Track: </label>
                <label class="details-label-info">{{trackData.trackName}}</label>
            </div>
            <div class="col-lg-6 marginbottom  text-left">
                <label class="details-label">Pole: </label>
                <label v-if="showPoleLap" class="details-label-info">{{trackData.pole}}</label>
                <input v-if="!showPoleLap"  type="number" step="0.01" value="0" v-model="updateData.poleTime" />&nbsp;
                <select v-if="!showPoleLap" class="sel-drivers" v-model="updateData.poleDriver">
                    <option v-for="item in drivers" :value="item.id">
                        {{ item.name }}
                    </option>
                </select>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-6 marginbottom  text-left">
                <label class="details-label">Fastest Lap: </label>
                <label v-if="showFastLap" class="details-label-info">{{trackData.fastestLap}}</label>
                <input v-if="!showFastLap" type="number" step="0.01" value="0" v-model="updateData.fastestLapTime" />&nbsp;
                <select v-if="!showFastLap" class="sel-drivers" v-model="updateData.fastestLapDriver">
                    <option v-for="item in drivers" :value="item.id">
                        {{ item.name }}
                    </option>
                </select>

            </div>
            <div class="col-lg-6 marginbottom  text-left">
                <label class="details-label">Race Date: </label>
                <label class="details-label-info">{{trackData.raceDate}}</label>
            </div>
        </div>
        <div class="row">
            <div v-if="firstError" class="col-lg-12 marginbottom  text-left">
                <span class="validation-error">! A 1st place must be set</span>
            </div>
        </div>
        </br>
        <table id="driver-results">
            <thead>
            <th>Position</th>
            <th>Driver</th>
            <th>Gap</th>
            </thead>
            <tbody>
                <tr v-for="driver in drivers" class="item">
                    <td><input type="number" class="position" /></td>
                    <td>
                        <select class="sel-drivers" v-model="driver.teamId">
                            <option v-for="item in drivers" :value="item.id">
                                {{ item.name }}
                            </option>
                        </select>
                    </td>
                    <td>
                        <input class="gap" type="number" step=0.01 />
                    </td>
                </tr>
            </tbody>
        </table>
        </br>
        <div class="row">
            <div class="col-lg-12 marginbottom  text-right"><button v-on:click="updateResult" class="btn-primary" id="btn_update">Update</button></div>
        </div>
    </div>


    </div>

@section scripts
{
    <script>

            var raceId = @ViewData["Id"];
            require.config({
                baseUrl: "/js"
            });

            require(["VueScripts/driverResults/updateDriverResult"],
                function (v) {

                }
            );
    </script>
}


