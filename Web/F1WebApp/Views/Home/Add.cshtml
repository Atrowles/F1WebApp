

<h1>Add Race</h1>
<div id="addEditRaceResult" class="rcorners" v-cloak>

    <div id="loading" v-if="showLoading" v-cloak>
        <img src="~/img/spinner.gif" />
    </div>

    <div class="row">
        <div  class="col-lg-6 marginbottom  text-left">
            <span v-if="raceDateError" class="validation-error">! Invalid Race Date Value</span>
        </div>
        <div  class="col-lg-6 marginbottom  text-left">
            <span v-if="locationError" class="validation-error">! Invalid Location Value</span>
        </div>
    </div>
    <div class="row">
        <div class="col-md-3 marginbottom  text-left">
            <span>Race Date: </span>
        </div>
        <div class="col-md-3 marginbottom  text-left">
            <input type="date" v-model="raceResult.raceDate" />
        </div>
        <div class="col-md-3 marginbottom  text-left">
            <span>Location : </span>
        </div>
        <div class="col-md-3 marginbottom  text-left">
            <select id="sel-location" v-model="raceResult.trackId">
                <option v-for="item in tracks" :value="item.id">
                    {{ item.name }}
                </option>
            </select>
        </div>

    </div>
    </br>
    <div class="row">
        <div class="col-md-3 marginbottom  text-left">
            <span>Pole Lap: </span>
        </div>
        <div class="col-md-3 marginbottom  text-left">
            <input type="number" step="0.01" value="0" v-model="raceResult.poleTime" />
        </div>
        <div class="col-md-3 marginbottom  text-left">
            <span>Pole Lap Driver : </span>
        </div>
        <div class="col-md-3 marginbottom  text-left">
            <select id="sel-driverPoleLap" v-model="raceResult.poleDriver">
                <option v-for="item in drivers" :value="item.id">
                    {{ item.name }}
                </option>
            </select>
        </div>
    </div>
    </br>
    <div class="row">
        <div class="col-md-3 marginbottom  text-left">
            <span>Fastest Lap: </span>
        </div>
        <div class="col-md-3 marginbottom  text-left">
            <input type="number" step="0.01" value="0" v-model="raceResult.fastestLapTime" />
        </div>
        <div class="col-md-3 marginbottom  text-left">
            <span>Fastest Lap Driver : </span>
        </div>
        <div class="col-md-3 marginbottom  text-left">
            <select id="sel-driverFastLap" v-model="raceResult.fastestLapDriver">
                <option v-for="item in drivers" :value="item.id">
                    {{ item.name }}
                </option>
            </select>
        </div>
    </div>



    </br>
    <div class="row">
        <div class="col-lg-12 marginbottom  text-left"><button v-on:click="validateRace" class="btn-primary">Add</button></div>
    </div>

</div>

@section scripts
{
    <script>



        require.config({
           baseUrl: "/js"
        });

        require(["VueScripts/RaceResults/AddEditRaceResult"],
                        function (v) {

                        }
       );
    </script>
}
